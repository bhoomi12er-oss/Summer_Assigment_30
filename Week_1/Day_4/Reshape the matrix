class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        vector <vector<int>> ans;
      
      int idx=0;
      if(mat.size()* mat[0].size() != r*c){
        return mat;
      }
      for(int i=0;i<r;i++){
         vector<int> arr;
        for(int j=0;j<c;j++){
            arr.push_back(mat[idx/mat[0].size()][idx%mat[0].size()]);
            idx++;
        }
         ans.push_back(arr);
      } 
    
      return ans;
    }
};
